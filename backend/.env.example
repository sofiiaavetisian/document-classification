# Document Intelligence Backend — environment variables
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# TOKENIZERS_PARALLELISM must always be false on macOS Python 3.9+.
# It is also set programmatically in pipeline.py, but setting it here
# ensures it is in the environment before any subprocess can inherit it.
TOKENIZERS_PARALLELISM=false

# HuggingFace offline mode — prevents any accidental Hub calls at runtime.
# Remove these lines if you intentionally want Hub access (e.g. to update
# the base DiT model from the cache).
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
